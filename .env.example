# Oracle base URL — production deployment of base-token-oracle
ORACLE_URL=https://svm402.com

# EVM wallet private key (Base mainnet, chainId 8453).
# Must hold a small amount of USDC at 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913.
# A few cents is enough for testing — /report costs $0.01 USDC per call.
# Format: 64 hex characters (32 bytes). 0x prefix is optional.
PRIVATE_KEY=

# Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: model override
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Optional: client-side spend cap (USDC). The agent refuses tool calls
# that would push cumulative spend past this number.
MAX_SPEND_USDC=0.10

# Optional: 1 enables verbose request/header/receipt logging
DEBUG=0

# Telegram Bot configuration (optional, bot starts if provided)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# DexScreener-driven watchlist scheduler
# Path to the built dex-screener-mcp server (default: ../dex-screener-mcp/dist/index.js)
DEXSCREENER_MCP_PATH=
# Toggle the periodic scan loop (default: 1)
SCHEDULER_ENABLED=1
# How often (in minutes) to fetch trending Base tokens and cross-reference (default: 60)
SCHEDULER_INTERVAL_MINUTES=60
# Maximum tokens kept on the curated watchlist (default: 10)
WATCHLIST_MAX_SIZE=10
# Path to the SQLite watchlist database (default: ./data/watchlist.db)
WATCHLIST_DB_PATH=

# === Automated trading engine (Base mainnet) ===
# Optional: dedicated Base RPC URL (recommended). The default public RPC
# (mainnet.base.org) is aggressively rate-limited and will cause "over rate
# limit" errors during quoting/decimals reads. Set this to a provider URL
# (Alchemy, Infura, QuickNode, Ankr, etc.) for live use.
BASE_RPC_URL=
# Master switch for the trading engine (default: 0 — disabled).
TRADING_ENABLED=0
# Real-trade switch. Must be 1 to send actual swaps; otherwise everything is dry-run.
TRADING_LIVE=0
# Watchlist score threshold; auto-buy fires when an add/replace event has score >= this.
TRADING_MIN_SCORE=80
# Fixed entry size in USDC per trade.
TRADE_SIZE_USDC=5
# Hard cap on simultaneously open positions.
MAX_OPEN_POSITIONS=3
# Take-profit %, stop-loss %, trailing-stop %, and max hold (minutes).
TP_PCT=50
SL_PCT=20
TRAILING_STOP_PCT=15
MAX_HOLD_MINUTES=1440
# Slippage tolerance in basis points (100 = 1%). Clamped to 1..500.
TRADING_SLIPPAGE_BPS=100
# How often to re-mark open positions, in seconds.
TRADING_MONITOR_INTERVAL_SEC=60
# DEX adapter to use (only "uniswap-v3" is supported initially).
TRADING_DEX=uniswap-v3
# Path to the SQLite trading database (default: ./data/trading.db).
TRADING_DB_PATH=
