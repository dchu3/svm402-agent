# Oracle base URL — production deployment of base-token-oracle
ORACLE_URL=https://svm402.com

# EVM wallet private key (Base mainnet, chainId 8453).
# Must hold a small amount of USDC at 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913.
# A few cents is enough for testing — /report costs $0.03 USDC per call.
# Format: 64 hex characters (32 bytes). 0x prefix is optional.
PRIVATE_KEY=

# Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: model override
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Optional: client-side spend cap (USDC). The agent refuses tool calls
# that would push cumulative spend past this number.
MAX_SPEND_USDC=0.10

# Optional: 1 enables verbose request/header/receipt logging
DEBUG=0

# Telegram Bot configuration (optional, bot starts if provided)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
