{
  "name": "svm402-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Gemini-driven CLI agent that exercises the base-token-oracle x402 payment flow on Base mainnet.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/evm": "^2.10.0",
    "@x402/fetch": "^2.10.0",
    "better-sqlite3": "^12.9.0",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "telegraf": "^4.16.3",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
